@@ -132,7 +132,12 @@ function transformGfmAutolinkLiterals(tree) {
     tree,
     [
       [/(https?:\/\/|www(?=\.))([-.\w]+)([^ \t\r\n]*)/gi, findUrl],
-      [/(?<=^|\s|\p{P}|\p{S})([-.\w+]+)@([-\w]+(?:\.[-\w]+)+)/gu, findEmail]
+      // Lookbehind removed: Safari <16.4 / iOS <16.4 fail to PARSE this module
+      // (`SyntaxError: Invalid regular expression: invalid group specifier name`),
+      // taking down the whole bundle chunk. The preceding-character constraint is
+      // already enforced at runtime by `previous(match, true)` in `findEmail`, so
+      // dropping the lookbehind preserves behavior.
+      [/([-.\w+]+)@([-\w]+(?:\.[-\w]+)+)/gu, findEmail]
     ],
     {ignore: ['link', 'linkReference']}
   )
