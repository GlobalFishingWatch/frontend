{
  "name": "ocean-areas",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ocean-areas/src",
  "projectType": "library",
  "targets": {
    "dist": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/ocean-areas",
        "main": "libs/ocean-areas/src/index.ts",
        "tsConfig": "libs/ocean-areas/tsconfig.lib.json",
        "assets": []
      }
    },
    "publish": {
      "command": "node tools/scripts/publish.mjs ocean-areas {args.ver} {args.tag}",
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/ocean-areas/**/*.ts", "libs/ocean-areas/package.json"]
      }
    }
  },
  "tags": []
}
