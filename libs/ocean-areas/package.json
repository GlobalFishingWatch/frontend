{
  "name": "@globalfishingwatch/ocean-areas",
  "version": "2.0.3",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "mpas": "node --loader ts-node/esm src/scripts/mpas.ts",
    "fao": "node --loader ts-node/esm src/scripts/fao.ts",
    "eezs": "node --loader ts-node/esm src/scripts/eezs.ts",
    "rfmos": "node --loader ts-node/esm src/scripts/rfmos.ts",
    "locales": "node --loader ts-node/esm src/scripts/locales.ts",
    "ports": "node --loader ts-node/esm src/scripts/ports.ts",
    "prepare": "pnpm mpas && pnpm eezs && pnpm rfmos && pnpm fao && pnpm locales"
  },
  "dependencies": {
    "@turf/turf": "7.x",
    "dotenv": "17.x",
    "es-toolkit": "1.x",
    "geojson": "0.x",
    "match-sorter": "8.x",
    "tslib": "2.x"
  },
  "devDependencies": {
    "@types/lodash": "4.x",
    "@types/node": "20.x",
    "dotenv": "^17.2.0",
    "ts-node": "10.x",
    "typescript": "5.x"
  }
}
