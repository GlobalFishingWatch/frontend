{
  "name": "pbf-decoders",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/pbf-decoders",
  "projectType": "library",
  "tags": ["lib"],
  "targets": {
    "prepare": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/pbf-decoders",
        "commands": [
          "make-dir decoders",
          "pbjs proto/vessels.proto -t static-module -w es6 -o decoders/vessels.js",
          "pbts decoders/vessels.js -o decoders/vessels.d.ts",
          "pbjs proto/4wings-tile.proto -t static-module -w es6 -o decoders/4wings-tile.js",
          "pbts decoders/4wings-tile.js -o decoders/4wings-tile.d.ts",
          "prettier --write \"./decoders/**.*\" -c ../../.prettierrc"
        ],
        "parallel": false
      }
    },
    "dist": {
      "executor": "@nx/js:tsc",
      "options": {
        "main": "libs/pbf-decoders/index.ts",
        "rootDir": "libs/pbf-decoders",
        "generatePackageJson": true,
        "assets": [{ "glob": "**/*", "input": "libs/pbf-decoders/decoders", "output": "decoders" }]
      }
    },
    "publish": {
      "executor": "@nx/js:release-publish",
      "dependsOn": ["dist"],
      "options": {
        "packageRoot": "libs/pbf-decoders"
      }
    }
  }
}
