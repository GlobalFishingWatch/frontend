{
  "name": "timebar",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/timebar/src",
  "projectType": "library",
  "tags": ["lib"],
  "targets": {
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "command": "vitest run --config=vitest.config.mts",
        "cwd": "libs/timebar",
        "reportsDirectory": "{projectRoot}/../../coverage/libs/timebar"
      }
    },
    "dist": {
      "executor": "@nx/js:tsc",
      "options": {
        "assets": [{ "glob": "**/*.css", "input": "libs/timebar/src", "output": "." }]
      }
    },
    "dev": {
      "dependsOn": ["^dev"],
      "executor": "@nx/js:tsc",
      "cache": false,
      "options": {
        "watch": true
      },
      "continuous": true
    },
    "publish": {
      "executor": "@nx/js:release-publish",
      "dependsOn": ["dist"],
      "options": {
        "packageRoot": "libs/timebar"
      }
    }
  }
}
