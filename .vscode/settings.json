{
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "js/ts.tsserver.maxMemory": 8192,
  "js/ts.tsserver.enableProjectDiagnostics": false,
  "js/ts.tsserver.watchOptions": {
    "watchFile": "useFsEventsOnParentDirectory",
    "watchDirectory": "useFsEvents",
    "fallbackPolling": "dynamicPriorityPolling",
    "excludeDirectories": [
      "**/node_modules",
      "**/.next",
      "**/dist",
      "**/.nx",
      "**/coverage",
      "**/.turbo",
      "**/build",
      "**/out",
      "**/exported",
      "**/tmp",
      "**/cypress",
      "**/e2e"
    ],
    "excludeFiles": [
      "**/*.spec.ts",
      "**/*.spec.tsx",
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.tsbuildinfo",
      "**/i18n.types.d.ts"
    ]
  },
  "js/ts.preferences.includePackageJsonAutoImports": "off",
  "js/ts.suggest.autoImports": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.suggest.completeFunctionCalls": true,
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.disableAutomaticTypeAcquisition": true,
  "editor.rulers": [140],
  "editor.formatOnSave": true,
  "eslint.format.enable": true,
  "eslint.lintTask.enable": true,
  "eslint.useFlatConfig": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": false,
    "**/.nx": true,
    "**/.turbo": true,
    "**/.tanstack": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/build/**": true,
    "**/dist/**": true,
    "**/.nx/**": true,
    "**/.turbo/**": true,
    "**/coverage/**": true,
    "**/*.tsbuildinfo": true,
    "**/out/**": true,
    "**/exported/**": true,
    "**/tmp/**": true,
    "**/cypress/**": true,
    "**/e2e/**": true
  },
  "search.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.output": true,
    "**/.tanstack": true,
    "**/.next": true,
    "**/.nx": true,
    "**/.turbo": true,
    "**/coverage": true,
    "**/workers": true,
    "**/*.tsbuildinfo": true,
    "**/.pnpm-store": true
  },
  "nxConsole.generateAiAgentRules": true
}
