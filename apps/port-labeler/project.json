{
  "name": "port-labeler",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/port-labeler/src",
  "projectType": "application",
  "targets": {
    "watch-deps": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx watch --projects port-labeler --includeDependentProjects -- nx run-many -t build -p \\$NX_PROJECT_NAME --exclude=port-labeler"
      },
      "continuous": true
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx build port-labeler --parallel"
      }
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/port-labeler"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx serve i18n-labels", "vite"],
        "cwd": "{projectRoot}",
        "parallel": true
      },
      "continuous": true
    },
    "preview": {
      "executor": "@nx/vite:preview-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "port-labeler:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "port-labeler:build:development"
        },
        "production": {
          "buildTarget": "port-labeler:build:production"
        }
      },
      "dependsOn": ["build"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project apps/port-labeler/tsconfig.json"
      }
    },
    "typecheck-watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --watch --project apps/port-labeler/tsconfig.json"
      },
      "continuous": true
    }
  },
  "tags": ["app"]
}
